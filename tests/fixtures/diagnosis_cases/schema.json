{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Diagnosis Fixture Expected Result",
  "type": "object",
  "required": [
    "case_id",
    "title",
    "source_type",
    "expected_issue_keys"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "official_sample",
        "synthetic",
        "self_made",
        "forum_sample"
      ]
    },
    "expected_issue_keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_severities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "error",
          "warning"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
