{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "cae-local-venv",
          "cmd": "E:\\cae-cli\\venv\\Scripts\\cae.exe",
          "args": true
        },
        {
          "name": "cae-project-venv",
          "cmd": "venv\\Scripts\\cae.exe",
          "args": true
        },
        {
          "name": "cae-path",
          "cmd": "cae",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "cae-local-venv",
          "cmd": "E:\\cae-cli\\venv\\Scripts\\cae.exe",
          "args": true
        },
        {
          "name": "cae-project-venv",
          "cmd": "venv\\Scripts\\cae.exe",
          "args": true
        },
        {
          "name": "cae-path",
          "cmd": "cae",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
